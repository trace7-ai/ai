{
  "version": "v1",
  "type": "object",
  "required": ["version", "status", "role", "model", "content_type", "errors", "token_usage"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "role": {
      "type": ["string", "null"]
    },
    "request_id": {
      "type": ["string", "null"]
    },
    "content_type": {
      "type": ["string", "null"],
      "enum": ["structured", "markdown", "text", null]
    },
    "session": {
      "type": ["object", "null"],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "turn_index": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        },
        "reason": {
          "type": ["string", "null"]
        },
        "ttl_seconds": {
          "type": ["integer", "null"]
        },
        "expires_at": {
          "type": ["string", "null"]
        }
      }
    },
    "files_read": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          }
        }
      }
    },
    "model": {
      "type": ["string", "null"]
    },
    "result": {
      "type": ["object", "string", "null"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "token_usage": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": {
          "type": ["integer", "null"]
        },
        "output": {
          "type": ["integer", "null"]
        }
      }
    },
    "truncated": {
      "type": "boolean"
    }
  }
}
